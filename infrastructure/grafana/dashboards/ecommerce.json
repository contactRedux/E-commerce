      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"gateway\"}[1m])) by (le, uri))",
          "legendFormat": "p99 {{uri}}",
          "refId": "A"
        }
      ],
      "title": "Gateway — P99 Latency",
