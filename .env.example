# ─────────────────────────────────────────────────────────────────────────────
# E-Commerce Platform — Environment Variable Reference
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ─── JWT ─────────────────────────────────────────────────────────────────────
# RS256 asymmetric key pair. Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_SECRET=your-very-long-random-secret-here-min-256-bits
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_EXPIRATION_MS=86400000

# ─── Database — User Service ──────────────────────────────────────────────────
USER_DB_HOST=postgres-user
USER_DB_PORT=5432
USER_DB_NAME=userdb
USER_DB_USER=userservice
USER_DB_PASSWORD=changeme_user

# ─── Database — Order Service ─────────────────────────────────────────────────
ORDER_DB_HOST=postgres-order
ORDER_DB_PORT=5432
ORDER_DB_NAME=orderdb
ORDER_DB_USER=orderservice
ORDER_DB_PASSWORD=changeme_order

# ─── Database — Payment Service ───────────────────────────────────────────────
PAYMENT_DB_HOST=postgres-payment
PAYMENT_DB_PORT=5432
PAYMENT_DB_NAME=paymentdb
PAYMENT_DB_USER=paymentservice
PAYMENT_DB_PASSWORD=changeme_payment

# ─── MongoDB — Product Service ────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/productdb
MONGO_DB_NAME=productdb

# ─── Redis — Cart Service & Gateway Rate Limiter ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── Consul ──────────────────────────────────────────────────────────────────
CONSUL_HOST=consul
CONSUL_PORT=8500

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ─── SendGrid ────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ─── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

# ─── Notification ────────────────────────────────────────────────────────────
NOTIFICATION_FROM_EMAIL=noreply@ecommerce.local

# ─── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SSL_KEYSTORE_PATH=/app/certs/keystore.p12
SSL_KEYSTORE_PASSWORD=changeme_keystore

# ─── Cart ────────────────────────────────────────────────────────────────────
CART_TTL_DAYS=7

# ─── Service Ports (internal Docker network) ─────────────────────────────────
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
CART_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
PAYMENT_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
